# Steward — environment configuration
#
# Steward: local-first FinOps for Kubernetes.
#
# Copy this file to .env and edit. The .env file is git-ignored.
# All defaults below are safe for local Docker Compose. For Postgres
# or non-Compose Ollama, see docs/CONFIGURATION.md.

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Fernet key for encrypting Kubecost auth tokens at rest in the database.
# Generate a fresh one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Never reuse keys across environments. Treat this like a database password.
SECRET_KEY=changeme-generate-a-real-key


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# SQLite (default — fine for single-operator installs)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Postgres (recommended if you'll have >1 environment or care about backups)
# DATABASE_URL=postgresql+asyncpg://kubecost:changeme@db:5432/kubecost_analyzer


# -----------------------------------------------------------------------------
# Ollama (the local LLM)
# -----------------------------------------------------------------------------

# Endpoint of the Ollama daemon. Default works inside Docker Compose.
# If you're running Ollama on the host instead, use http://host.docker.internal:11434
OLLAMA_HOST=http://ollama:11434

# Default model. Must be pulled separately via:
#   docker compose exec ollama ollama pull qwen2.5:7b-instruct
# Other tested options: qwen2.5:14b-instruct (better, needs ~14 GB RAM)
OLLAMA_MODEL=qwen2.5:7b-instruct


# -----------------------------------------------------------------------------
# ChromaDB (RAG corpus)
# -----------------------------------------------------------------------------

CHROMA_HOST=chromadb
CHROMA_PORT=8000


# -----------------------------------------------------------------------------
# Redis (arq job queue)
# -----------------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# Frontend → Backend wiring
# -----------------------------------------------------------------------------

# The browser-visible backend URL. For local dev this is http://localhost:8000.
# When deploying behind a reverse proxy, set to the externally reachable URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated allowlist for browser origins. Lock this down in production
# — leaving it permissive lets any site call the backend from a user's browser.
CORS_ORIGINS=http://localhost:3000


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# DEBUG, INFO, WARNING, ERROR. INFO is fine for production.
LOG_LEVEL=INFO
